<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>

  <!-- ============================================================
       CADENA DE CONEXIÓN – XAMPP MySQL (sin contraseña)
       Si cambias el puerto o la contraseña, modifica aquí.
       ============================================================ -->
  <connectionStrings>
    <add name="AcademiaDB"
         connectionString="server=127.0.0.1;port=3306;database=academia_ingles;uid=root;pwd=;charset=utf8mb4;Allow User Variables=True;SslMode=None;"
         providerName="MySql.Data.MySqlClient" />
  </connectionStrings>

</configuration>
